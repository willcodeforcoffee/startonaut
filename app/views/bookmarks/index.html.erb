<% content_for :title, "Bookmarks" %>
<div class="w-full font-pt-sans">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>
  <div class="flex justify-between items-center">
    <h1 class="font-pt-sans font-bold text-4xl">Bookmarks</h1>
    <%= primary_link_to "New bookmark", new_bookmark_path %>
  </div>
  <div id="bookmarks" class="min-w-full divide-y divide-gray-200 space-y-5">
    <div id="search" class="flex flex-col mt-5">
      <%= form_with url: bookmarks_path, method: :get, class: "flex space-x-2" do %>
        <%= text_field_tag :q, params[:q], placeholder: "Search bookmarks by title...", class: "flex-1 rounded-md border-gray-300" %>
        <%= submit_tag "Search", name: nil, class: (ThemeHelper::THEME_LINK_CLASSES + ThemeHelper::THEME_LINK_STYLES[:secondary]).join(" ") %>
      <% end %>
    </div>
    <% if @bookmarks.any? %>
      <% @bookmarks.each do |bookmark| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render "bookmark_small", bookmark: bookmark %>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No bookmarks found.</p>
    <% end %>
  </div>
</div>
